{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["es2020", "esnext"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noImplicitAny": false,
    "removeComments": true,
    "preserveConstEnums": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "esModuleInterop": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "node_modules"]
}
